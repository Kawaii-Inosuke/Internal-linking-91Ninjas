# Copy to `.env` and fill in. Never commit the real .env (see .gitignore).

# --- Secrets -------------------------------------------------------------
# Postgres 16 + pgvector connection string (required)
DATABASE_URL=postgresql://user:pass@localhost:5432/linker

# Gemini API key: https://aistudio.google.com/apikey
# NOT used for embeddings (those run locally). Needed only for the M3 LLM
# relevance gate (Gemini Flash); leave blank until then.
GEMINI_API_KEY=

# Google Docs service-account credentials (used from M4 onwards)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# --- Embeddings (local, sentence-transformers) ---------------------------
# Local model — no API key, no rate limit. First run downloads it (~hundreds
# of MB), a one-time cost; after that it runs fully offline.
# Must be a 768-dim model; EMBED_DIM must match schema.sql vector(768).
EMBED_MODEL=BAAI/bge-base-en-v1.5
EMBED_DIM=768
# Texts per sentence-transformers encode batch (any positive int; larger uses
# more memory). No inter-request throttle — a local model has no rate limit.
EMBED_BATCH_SIZE=32

# --- LLM relevance gate (used from M3 onwards) ---------------------------
# Verify the current free-tier Flash model at build time.
LLM_MODEL=gemini-flash-latest

# --- Matching tunables (used from M2/M3 onwards) -------------------------
TOP_K=10
SIM_THRESHOLD=0.75
MAX_LINKS_PER_PARAGRAPH=2
MAX_TOTAL_LINKS=15
RRF_K=60
