# Copy to `.env` and fill in. Never commit the real .env (see .gitignore).

# --- Secrets -------------------------------------------------------------
# Gemini API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Postgres 16 + pgvector connection string
DATABASE_URL=postgresql://user:pass@localhost:5432/linker

# Google Docs service-account credentials (used from M4 onwards)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# --- Embeddings ----------------------------------------------------------
# Model names change over time — verify the current model at build time.
# Must be a 768-dim-capable model; EMBED_DIM must match schema.sql vector(768).
EMBED_MODEL=gemini-embedding-001
EMBED_DIM=768
# Texts per embedding request (Gemini caps this at 100).
EMBED_BATCH_SIZE=100
# Seconds to wait between embedding requests to respect free-tier RPM
# (in addition to reactive 429 backoff); set 0 to disable throttling.
EMBED_THROTTLE_SECONDS=0.5

# --- LLM relevance gate (used from M3 onwards) ---------------------------
# Verify the current free-tier Flash model at build time.
LLM_MODEL=gemini-flash-latest

# --- Matching tunables (used from M2/M3 onwards) -------------------------
TOP_K=10
SIM_THRESHOLD=0.75
MAX_LINKS_PER_PARAGRAPH=2
MAX_TOTAL_LINKS=15
RRF_K=60
